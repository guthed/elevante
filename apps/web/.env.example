# Loops.io — e-postmotor (kontakt-/lead-/investerarnotiser + skol-kontaktmejl).
# Utan LOOPS_API_KEY loggas alla utskick bara (graceful fallback), inget skickas.
# Samma nyckel används av scripts/loops-create-templates.mjs för att skapa mallarna.
LOOPS_API_KEY=
# Transactional-mallarnas ID:n (fylls i av loops-create-templates.mjs, eller kopieras från Loops).
LOOPS_SKOL_KONTAKT_ID=
LOOPS_LEAD_NOTIS_ID=
LOOPS_KONTAKT_NOTIS_ID=
LOOPS_INVESTOR_NOTIS_ID=

# Supabase — dedikerat Elevante-projekt (eu-central-2 / Zurich)
NEXT_PUBLIC_SUPABASE_URL=https://msqfuywpbrteyrzjggsw.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_bh7JKy0mMPqZwl9WGYZcpg_LozjyEQ2
SUPABASE_SERVICE_ROLE_KEY=

# Notion (kampanj-prospekt-sync). Utan dessa hoppas Notion-synk över tyst.
NOTION_TOKEN=
NOTION_LEADS_DATABASE_ID=
NOTION_SHARES_DATABASE_ID

# Anthropic (Claude RAG-svar). Utan denna används mockedAnswer.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Berget AI (KB-Whisper transkribering + embeddings).
# Utan dessa körs ingen audio-pipeline och RAG faller tillbaka till mockedAnswer.
BERGET_AI_API_KEY=
BERGET_AI_BASE_URL=https://api.berget.ai/v1
BERGET_AI_TRANSCRIBE_MODEL=KBLab/kb-whisper-large
BERGET_AI_EMBED_MODEL=intfloat/multilingual-e5-large

# Serverhemlighet som signerar investerardeckets sessions-cookie (valfri stark sträng).
INVESTOR_DECK_SECRET=
# Mottagare för investerardeck-notiser (default: CONTACT_TO_EMAIL → john@elevante.se).
INVESTOR_NOTIFY_EMAIL=

# Notion-integration för investerardeck-dashboarden (server-only).
NOTION_TOKEN=
NOTION_INVESTOR_DB_ID=
