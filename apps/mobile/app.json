{
  "expo": {
    "name": "Elevante",
    "slug": "elevante-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "elevante",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "se.elevante.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Elevante behöver mikrofonåtkomst för att spela in lektioner. Inspelningarna används endast för transkribering och raderas direkt efteråt.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "se.elevante.app",
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF7F2"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Elevante behöver mikrofonåtkomst för att spela in lektioner."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
